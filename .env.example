# Iceberg App - Configuración de Entorno (Ejemplo)
# --------------------------------------------------

# Copia este archivo como .env para usar variables de entorno locales.
# Aunque la app actualmente usa LocalStorage para la API Key por seguridad,
# este archivo sirve como referencia para futuros despliegues o tests.

VITE_GEMINI_API_KEY=tu_api_key_aqui
VITE_DEFAULT_MODEL=gemini-2.5-flash
