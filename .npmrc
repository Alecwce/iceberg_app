# Iceberg App - Security & Supply Chain Protection
# --------------------------------------------------

# 1. Seguridad: Evitar ejecución de scripts maliciosos al instalar (anti-malware)
ignore-scripts=true

# 2. Estabilidad: Guardar versiones exactas de dependencias (evita bugs por actualizaciones automáticas)
save-exact=true

# 3. Prevención: No instalar paquetes con menos de 7 días de vida (periodo de cuarentena)
minimum-release-age=10080

# 4. Integridad: Bloquear subdependencias exóticas (protección de cadena de suministro)
block-exotic-subdeps=true
